# App
NODE_ENV=production
HOST=127.0.0.1
PORT=8787
CRYPTEDMAIL_APP_URL=https://your-domain.com

# Safety switch
# Keep true until you are ready for real USDC payments.
CRYPTEDMAIL_TEST_MODE=true

# Admin API
# Use a long random value. Required for /api/admin/config.
CRYPTEDMAIL_ADMIN_TOKEN=replace_with_long_random_admin_token

# Wallet checkout
CRYPTEDMAIL_RECEIVER_ADDRESS=0x0e1ed12CE5145E8135bE7f1aADDD59a698BaA421
CRYPTEDMAIL_NETWORK=base
WALLETCONNECT_PROJECT_ID=replace_with_walletconnect_project_id

# Base RPC
# Public fallback is https://mainnet.base.org, but production should use Alchemy/Infura/QuickNode/etc.
BASE_RPC_URL=https://mainnet.base.org

# Optional Polygon support
POLYGON_RPC_URL=https://polygon-rpc.com

# Supabase
SUPABASE_URL=https://asqqajeqroskekjsfbyy.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key_server_only

# Optional Vercel cron protection for /api/cron/reconcile
CRON_SECRET=replace_with_long_random_cron_secret
